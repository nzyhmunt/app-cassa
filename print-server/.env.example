# Porta HTTP del server di stampa (default: 3001)
PORT=3001

# Tipo di connessione stampante: 'tcp' (rete) oppure 'file' (USB/parallela)
PRINTER_TYPE=tcp

# --- Opzioni per PRINTER_TYPE=tcp ---
# IP o hostname della stampante di rete
PRINTER_HOST=127.0.0.1
# Porta TCP della stampante (quasi sempre 9100)
PRINTER_PORT=9100
# Timeout connessione TCP in millisecondi
PRINTER_TCP_TIMEOUT_MS=5000

# --- Opzioni per PRINTER_TYPE=file ---
# Percorso del file di dispositivo (Linux: /dev/usb/lp0, Windows: \\.\COM1)
PRINTER_DEVICE=/dev/usb/lp0

# Nome del server mostrato nei log
PRINT_SERVER_NAME=ESC/POS Print Server
