# Porta HTTP del server di stampa (default: 3001)
PORT=3001

# Nome del server mostrato nei log
PRINT_SERVER_NAME=ESC/POS Print Server

# (Opzionale) API key richiesta nell'header x-api-key su POST /print.
# Se non impostata, POST /print non richiede autenticazione.
# PRINT_SERVER_API_KEY=cambia-questa-chiave-segreta

# (Opzionale) Lista di origini CORS consentite, separate da virgola.
# Se vuota, tutte le origini sono accettate (default aperto).
# Utile per bloccare richieste cross-origin da siti non autorizzati in LAN.
# CORS_ALLOWED_ORIGINS=http://localhost:8080,http://192.168.1.50:8080

# ── Configurazione stampanti tramite variabili d'ambiente (opzionale) ─────────
#
# Se impostata almeno una variabile PRINTER_<N>_ID, le stampanti vengono lette
# da queste variabili al posto di printers.config.js.
# N inizia da 0 e deve essere consecutivo (es. 0, 1, 2 — senza salti).
#
# Stampante TCP (rete):
# PRINTER_0_ID=cucina
# PRINTER_0_NAME=Cucina
# PRINTER_0_TYPE=tcp
# PRINTER_0_HOST=192.168.1.100
# PRINTER_0_PORT=9100
# PRINTER_0_TIMEOUT=5000
#
# Seconda stampante TCP:
# PRINTER_1_ID=bar
# PRINTER_1_NAME=Bar
# PRINTER_1_TYPE=tcp
# PRINTER_1_HOST=192.168.1.101
# PRINTER_1_PORT=9100
#
# Stampante USB (file di dispositivo):
# PRINTER_2_ID=cassa
# PRINTER_2_NAME=Cassa
# PRINTER_2_TYPE=file
# PRINTER_2_DEVICE=/dev/usb/lp0

# ── Modalità Directus Pull (opzionale) ────────────────────────────────────────
#
# Se impostati DIRECTUS_URL e DIRECTUS_TOKEN, il print-server si connette
# direttamente a Directus e legge i lavori di stampa dalla collezione
# print_jobs autonomamente, senza che il browser faccia da intermediario.
#
# Il sistema usa due meccanismi complementari:
#   1. WebSocket subscription (real-time) — job processati istantaneamente
#      Utilizza il WebSocket nativo di Node.js 22+ tramite l'SDK Directus.
#   2. REST polling (fallback)            — recupero job persi durante disconnessioni
#
# Quando Directus è disponibile, la configurazione delle stampanti viene letta
# automaticamente dalla collezione `printers`. Le stampanti con connection_type
# 'tcp' o 'file' sovrascrivono printers.config.js e le variabili PRINTER_<N>_*.
# Le stampanti con connection_type 'http' vengono ignorate (usate dall'hook push).
#
# URL base di Directus (es. http://localhost:8055 o http://directus:8055)
# DIRECTUS_URL=http://localhost:8055
#
# Static token Directus con permessi read/write su print_jobs e read su printers
# DIRECTUS_TOKEN=il-tuo-static-token-directus
#
# (Opzionale) Filtra i job per venue ID (intero). Lascia vuoto per tutti i venue.
# DIRECTUS_VENUE_ID=1
#
# Intervallo del polling REST di fallback in secondi (default: 60, minimo: 5)
# DIRECTUS_POLL_SEC=60
#
# Tentativi di riconnessione WebSocket in caso di interruzione (default: 100)
# DIRECTUS_WS_RETRIES=100
#
# Attesa tra riconnessioni WebSocket in ms (default: 3000)
# DIRECTUS_WS_RETRY_DELAY=3000
#
# Numero massimo di tentativi per singolo job in caso di errore transitorio (default: 3)
# DIRECTUS_RETRY_MAX=3
#
# Attesa tra tentativi per singolo job in ms (default: 2000)
# DIRECTUS_RETRY_DELAY_MS=2000
#
# Intervallo di refresh della lista stampanti da Directus in secondi (default: 300)
# DIRECTUS_PRINTERS_REFRESH_SEC=300

