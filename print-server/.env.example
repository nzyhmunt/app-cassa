# Porta HTTP del server di stampa (default: 3001)
PORT=3001

# Nome del server mostrato nei log
PRINT_SERVER_NAME=ESC/POS Print Server

# ── Configurazione stampante demo (usata da printers.config.js) ──────────────
# Questi valori vengono letti da printers.config.js per la stampante con id='demo'.
# Per configurare più stampanti, editare direttamente printers.config.js.

# IP o hostname della stampante demo (solo TCP)
PRINTER_HOST=127.0.0.1
# Porta TCP della stampante (quasi sempre 9100)
PRINTER_PORT=9100
# Timeout connessione TCP in millisecondi
PRINTER_TCP_TIMEOUT_MS=5000
