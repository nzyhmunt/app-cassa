# Porta HTTP del server di stampa (default: 3001)
PORT=3001

# Nome del server mostrato nei log
PRINT_SERVER_NAME=ESC/POS Print Server

# (Opzionale) API key richiesta nell'header x-api-key su POST /print.
# Se non impostata, POST /print non richiede autenticazione.
# PRINT_SERVER_API_KEY=cambia-questa-chiave-segreta

# (Opzionale) Lista di origini CORS consentite, separate da virgola.
# Se vuota, tutte le origini sono accettate (default aperto).
# Utile per bloccare richieste cross-origin da siti non autorizzati in LAN.
# CORS_ALLOWED_ORIGINS=http://localhost:8080,http://192.168.1.50:8080

# ── Configurazione stampanti tramite variabili d'ambiente (opzionale) ─────────
#
# Se impostata almeno una variabile PRINTER_<N>_ID, le stampanti vengono lette
# da queste variabili al posto di printers.config.js.
# N inizia da 0 e deve essere consecutivo (es. 0, 1, 2 — senza salti).
#
# Stampante TCP (rete):
# PRINTER_0_ID=cucina
# PRINTER_0_NAME=Cucina
# PRINTER_0_TYPE=tcp
# PRINTER_0_HOST=192.168.1.100
# PRINTER_0_PORT=9100
# PRINTER_0_TIMEOUT=5000
#
# Seconda stampante TCP:
# PRINTER_1_ID=bar
# PRINTER_1_NAME=Bar
# PRINTER_1_TYPE=tcp
# PRINTER_1_HOST=192.168.1.101
# PRINTER_1_PORT=9100
#
# Stampante USB (file di dispositivo):
# PRINTER_2_ID=cassa
# PRINTER_2_NAME=Cassa
# PRINTER_2_TYPE=file
# PRINTER_2_DEVICE=/dev/usb/lp0
