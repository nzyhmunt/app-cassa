# Variabili d'ambiente — Print Dispatcher Extension

# Header x-api-key inviato ad ogni richiesta al print-server.
# Deve corrispondere a PRINT_SERVER_API_KEY configurato nel print-server.
# Lasciare vuoto se il print-server non richiede autenticazione.
PRINT_SERVER_API_KEY=

# Intervallo di polling per recuperare job pending rimasti indietro (secondi).
# Default: 60
PRINT_DISPATCHER_POLL_SEC=60

# Timeout HTTP per ogni richiesta al print-server (millisecondi).
# Default: 30000
PRINT_DISPATCHER_TIMEOUT_MS=30000

# Numero massimo di tentativi per ogni job in caso di errore transitorio (5xx / rete).
# Gli errori 4xx (payload non valido) non vengono ritentati.
# Default: 3
PRINT_DISPATCHER_RETRY_MAX=3

# Attesa tra un tentativo e il successivo (millisecondi).
# Default: 2000
PRINT_DISPATCHER_RETRY_DELAY_MS=2000
